{
	"name": "axis-models",
	"version": "0.0.0",
	"description": "TypeScript object models for AXIS: Light & Dark Elemental Dominion",
	"main": "dist/index.js",
	"scripts": {
		"board": "ts-node --project scripts/tsconfig.json scripts/printBoard.ts",
		"bot:smoke": "ts-node --project scripts/tsconfig.json scripts/botSmoke.ts",
		"build": "tsc",
		"compile": "tsc",
		"develop": "tsc --watch",
		"lint": "eslint ./src/**",
		"lint-fix": "eslint ./src/** --fix",
		"spec": "ts-mocha \"src/**/*.spec.ts\"",
		"spec:watch": "ts-mocha  \"src/**/*.spec.ts\" -w --watch-extensions ts",
		"test": "ts-mocha \"src/**/*.spec.ts\"",
		"test:watch": "ts-mocha \"src/**/*.spec.ts\" -w --watch-extensions ts"
	},
	"author": "Chris Moscoso",
	"license": "ISC",
	"dependencies": {
		"@moscoso/models": "file:../../models",
		"events": "^3.3.0",
		"short-uuid": "^6.0.3"
	},
	"//": "overrides: mocha@11.x ships serialize-javascript@^6 and diff@^7, both vulnerable. Remove overrides once mocha bumps its own deps. Check: npm show mocha@latest dependencies",
	"overrides": {
		"serialize-javascript": "^7.0.5",
		"diff": "^8.0.3"
	},
	"devDependencies": {
		"@types/chai": "^5.2.3",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"chai": "^6.2.2",
		"eslint": "^9.0.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-promise": "^7.2.1",
		"mocha": "^11.7.5",
		"ts-mocha": "^11.1.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^6.0.3"
	}
}
