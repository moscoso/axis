{
	"name": "axis-server",
	"version": "0.0.1",
	"description": "A websocket server for AXIS: Light & Dark Elemental Dominion",
	"main": "dist/start.js",
	"scripts": {
		"compile": "tsc",
		"build": "tsc",
		"develop": "ts-node-dev ./src/start --watch",
		"start": "node dist/start.js",
		"bot:smoke": "ts-node src/Server/BotRunner.smoke.ts",
		"test": "node -e \"console.log('axis-server: no specs yet — see bot:smoke')\"",
		"test:watch": "mocha --watch --watch-extensions ts --reporter spec --require ts-node/register src/**/*.spec.ts",
		"lint": "eslint src/**"
	},
	"author": "Chris Moscoso",
	"license": "ISC",
	"dependencies": {
		"axis-models": "*",
		"express": "^5.1.0",
		"rxjs": "^7.8.1",
		"socket.io": "^4.8.0"
	},
	"devDependencies": {
		"@types/chai": "^5.2.0",
		"@types/express": "^5.0.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"chai": "^6.2.2",
		"eslint": "^10.2.1",
		"mocha": "^11.0.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^6.0.3"
	}
}
